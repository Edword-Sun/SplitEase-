# 在服务器上复制为 .env 后再启动：
#   cp .env.example .env && nano .env
#
# 与 docker-compose.hub.yml 同目录执行 compose 时使用：
#   docker compose -f docker-compose.hub.yml --env-file .env up -d

DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=split_ease
DB_CHARSET=utf8mb4

# 浏览器访问 http://服务器IP:FRONTEND_PORT/ ；默认 3000，避免占用宿主机 80（与本机 Vite 端口习惯一致）
FRONTEND_PORT=3000

# 可选：固定某次构建的标签（不设则用 compose 里默认 latest）
# BACKEND_IMAGE=edwordddddddddd/split_ease-backend:latest
# FRONTEND_IMAGE=edwordddddddddd/split_ease-frontend:latest
